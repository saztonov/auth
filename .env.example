# Keycloak (infra) — пример окружения. Скопировать в .env и заполнить реальными значениями.
# .env НЕ коммитится (см. .gitignore). Секреты — в защищённом storage (Yandex Lockbox / файл 640
# root:docker); значения не выводить в логи и чат.

# --- Версия образа (pin, не latest) ---
KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:26.1

# --- БД keycloak_db (Yandex Managed PostgreSQL, отдельный пользователь, TLS) ---
# Порт Yandex обычно 6432. sslmode=require (или verify-full с CA).
KC_DB_URL=jdbc:postgresql://c-<cluster-id>.rw.mdb.yandexcloud.net:6432/keycloak_db?ssl=true&sslmode=require
KC_DB_USERNAME=keycloak_runtime
KC_DB_PASSWORD=<keycloak-db-password>
# Лимит пула к БД. conn_limit пользователя keycloak_runtime должен быть >= этого значения.
KC_DB_POOL_MAX_SIZE=20

# --- Hostname / issuer ---
KC_HOSTNAME=https://auth.su10.ru
KC_HOSTNAME_ADMIN=https://auth-admin.su10.ru

# --- Bootstrap-админ (ВРЕМЕННЫЙ). После создания постоянного админа удалить bootstrap-учётку
#     и убрать эти переменные из .env. ---
KC_BOOTSTRAP_ADMIN_USERNAME=bootstrap-admin
KC_BOOTSTRAP_ADMIN_PASSWORD=<strong-bootstrap-password>

# --- keycloak-config-cli (накат realm-as-code на живой Keycloak) ---
# Админ-учётка realm master для импорта конфигурации. Использовать постоянного админа, не bootstrap.
KC_CONFIG_CLI_IMAGE=adorsys/keycloak-config-cli:latest-26
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_ADMIN_USER=<realm-master-admin>
KEYCLOAK_ADMIN_PASSWORD=<realm-master-admin-password>

# --- Секреты клиентов для config-cli (подстановка $(env:...) в su10-realm.yaml) ---
# Значение = Client secret из Credentials соответствующего клиента (то же, что OIDC_CLIENT_SECRET портала).
ESTIMAT_CLIENT_SECRET=<estimat-client-secret>
BILLHUB_CLIENT_SECRET=<billhub-client-secret>

# --- SMTP — позже (сейчас verifyEmail/resetPasswordAllowed выключены). При включении:
# SMTP_PASSWORD=<smtp-password>
