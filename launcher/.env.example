# Витрина порталов su10 — переменные сборки (Vite). Скопировать в .env(.local).
# Публичные значения (не секреты): OIDC public-клиент, PKCE — секрет не нужен.

VITE_OIDC_AUTHORITY=https://auth.su10.ru/realms/su10
VITE_OIDC_CLIENT_ID=su10-launcher
# redirect/post-logout по умолчанию берутся из window.location.origin.
